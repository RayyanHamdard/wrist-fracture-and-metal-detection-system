# Base URL of the backend API (no trailing slash).
# Local dev:  http://localhost:8000
# Production: set this in your Vercel project's Environment Variables to your
#             deployed backend URL, e.g. https://your-backend.hf.space
VITE_API_URL=http://localhost:8000

# Groq API key for the chatbot (create one at https://console.groq.com).
# NOTE: VITE_ variables are bundled into the frontend build and are visible to
# end users. For real security, proxy Groq calls through the backend instead of
# calling the Groq API directly from the browser.
VITE_GROQ_API_KEY=

